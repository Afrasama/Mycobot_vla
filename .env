# =============================================================================
# Run profiles (edit flags below; keep comments on their own lines)
# =============================================================================
#
# Normal eval:
#   INJECT_PERCEPTION_FAILURE=0
#   VLA_DEMO_MODE=0
#   MAX_ROUNDS=5
#
# Single task + in-round LLM retries (recommended):
#   MAX_ROUNDS=1
#   MAX_ATTEMPTS=5
#   REFLECT_EVERY_ROUND=0
#   VLA_DEMO_MODE=0
#
# See VLA in log without fake failure:
#   VLA_DEMO_MODE=1
#
# Debug reflection + VLA (forced miss on attempt 1):
#   INJECT_PERCEPTION_FAILURE=1
#   MAX_ROUNDS=3
#
# Before runs: ollama serve, then `ollama pull llama3` and `llama3.2-vision`
# Reflection uses llama3; vision uses llama3.2-vision when pixel error is small.
# VLA recovery uses VLA_BACKEND=heuristic (local closed-loop, not OpenVLA).
# =============================================================================

LLM_AGENT_BACKEND=ollama
LLM_AGENT_ENDPOINT=http://localhost:11434/api/chat
LLM_AGENT_TIMEOUT_S=120
LLM_AGENT_USE_VISION=1
LLM_AGENT_MODEL=llama3.2-vision

# Qwen2.5 7B Instruct
# LLM_AGENT_MODEL=qwen2.5-7b-instruct-1m

# Deepseek Coder 6.7B
# LLM_AGENT_MODEL=deepseek-coder-6.7b-kexer

# MongoDB Configuration
MONGODB_URI=mongodb://localhost:27017/

# VLA recovery (local closed-loop by default — NOT OpenVLA)
USE_VLA_RECOVERY=1
# heuristic = local vision + world-error closed loop (no GPU model download)
# neural_local = your own HF checkpoint via VLA_MODEL_PATH
# openvla_local / openvla_api = OpenVLA (only if VLA_USE_OPENVLA=1)
VLA_BACKEND=heuristic
VLA_ON_ANY_PICK_FAILURE=1
VLA_DEMO_MODE=0
VLA_USE_OPENVLA=0
# VLA_MODEL_PATH=
# VLA_API_URL=http://localhost:8000/predict

# Reflection / evaluation — one pick-place task, retries on failure only
REFLECT_EVERY_ROUND=0
MAX_ROUNDS=1
MAX_ATTEMPTS=5
PIPELINE_EVAL_MODE=1
# First-attempt deliberate aim bias for pipeline-eval mode (meters)
PIPELINE_EVAL_MISS_X_M=0.022
PIPELINE_EVAL_MISS_Y_M=-0.018

# 0 = normal picks (recommended). 1 = bad perception for LLM only unless INJECT_AFFECTS_MOTION=1
INJECT_PERCEPTION_FAILURE=0
INJECT_AFFECTS_MOTION=0
