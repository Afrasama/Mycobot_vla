# Ollama Configuration
# Copy this file to .env and modify as needed

# Default Ollama Configuration
LLM_AGENT_BACKEND=ollama
LLM_AGENT_ENDPOINT=http://localhost:11434/api/chat
LLM_AGENT_MODEL=llama3.2-vision
LLM_AGENT_TIMEOUT_S=60
LLM_AGENT_USE_VISION=1

# Alternative Ollama Models (uncomment to use)
# LLM_AGENT_MODEL=llama3.2
# LLM_AGENT_MODEL=qwen2.5:7b
# LLM_AGENT_MODEL=deepseek-coder:6.7b

# MongoDB Configuration
MONGODB_URI=mongodb://localhost:27017/

# INJECT_PERCEPTION_FAILURE=1 simulates bad vision for LLM (reflection only by default)
# INJECT_AFFECTS_MOTION=1 also mis-aims the arm (stress test; often fails pick)
# INJECT_PERCEPTION_FAILURE=0
# INJECT_AFFECTS_MOTION=0

# Number of full pick-and-place cycles per run (1 = single task)
# MAX_ROUNDS=1
# In-round retries after failure (attempt 1 + MAX_ATTEMPTS retries; default 5)
# MAX_ATTEMPTS=5
# LLM after every round even on success (noisy); 0 = only on failure
# REFLECT_EVERY_ROUND=0

# Observe phase timeout (frames at 240 Hz; 3600 = 15 s)
# OBSERVE_TIMEOUT_FRAMES=3600

# Cube XY must stay in this annulus (meters from robot base at origin)
# MIN_REACH_DISTANCE_M=0.20
# MAX_REACH_DISTANCE_M=0.30

# Overhead task camera (orthographic top-down; used for vision / segmentation only)
# SAVE_OVERHEAD_FRAMES=1
# OVERHEAD_HALF_EXTENT_M=0.38
# OVERHEAD_DISTANCE_M=0.62
# OVERHEAD_WIDTH=640
# OVERHEAD_HEIGHT=480

# PyBullet GUI camera (3/4 view — easier to see joint motion than top-down)
# SYNC_DEBUG_WORKSPACE_CAMERA=1
# DEBUG_CAMERA_DISTANCE=1.05
# DEBUG_CAMERA_YAW=52
# DEBUG_CAMERA_PITCH=-38
# DEBUG_CAMERA_TARGET_X=0.22
# DEBUG_CAMERA_TARGET_Y=0.0
# DEBUG_CAMERA_TARGET_Z=0.10

# VLA recovery (default: local heuristic closed-loop, not OpenVLA)
# USE_VLA_RECOVERY=1
# VLA_BACKEND=heuristic
# VLA_ON_ANY_PICK_FAILURE=1
# VLA_DEMO_MODE=1
# VLA_USE_OPENVLA=0
# Pipeline-eval mode (forces recoverable failures so LLM + VLA retries actually run):
# PIPELINE_EVAL_MODE=1
# PIPELINE_EVAL_MISS_X_M=0.022
# PIPELINE_EVAL_MISS_Y_M=-0.018
# Optional neural local checkpoint (HuggingFace id or folder):
# VLA_BACKEND=neural_local
# VLA_MODEL_PATH=/path/to/your-vla-checkpoint
# OpenVLA only when explicitly enabled:
# VLA_USE_OPENVLA=1
# VLA_BACKEND=openvla_local
# VLA_MODEL_PATH=openvla/openvla-7b
# VLA_BACKEND=openvla_api
# VLA_API_URL=http://localhost:8000/predict

# LLM reflection between autonomous rounds (even when pick/place succeeds)
# REFLECT_EVERY_ROUND=1
# FORCE_REFLECTION=0
# FORCED_REFLECTION_ATTEMPTS=1


